  "DamageScenarios": [
    {
      "_id": "abs_ds_001",
      "model_id": "abs_model_001",
      "type": "damage",
      "derivation": [
        {
          "id": "abs_deriv_1",
          "nodeId": "abs_code_flash",
          "task": "Threat Analysis",
          "name": "CWE-494: Download of Code Without Integrity Check",
          "loss": "Unauthorized firmware modification via OTA or diagnostic service",
          "asset": "Code Flash",
          "damage_scene": "An attacker delivers a tampered firmware image to the ABS ECU through an unsecured OTA channel or an unlocked UDS 0x34/0x36 session. The modified firmware disables the wheel lock prevention logic, causing the ABS to fail silently and creating a life-threatening loss-of-braking condition.",
          "isChecked": false
        },
        {
          "id": "abs_deriv_2",
          "nodeId": "abs_keys",
          "task": "Threat Analysis",
          "name": "CWE-321: Use of Hard-coded Cryptographic Key",
          "loss": "Compromise of ECU authentication and seed-key mechanism",
          "asset": "Keys",
          "damage_scene": "Reverse-engineering of the ABS ECU binary reveals a hard-coded seed-key algorithm. An attacker gains full UDS SecurityAccess (service 0x27), enabling arbitrary memory read/write and firmware reprogramming without valid workshop credentials.",
          "isChecked": false
        },
        {
          "id": "abs_deriv_3",
          "nodeId": "abs_wheel_speed_sensors",
          "task": "Threat Analysis",
          "name": "CAPEC-390: Bypassing of Intermediate Forms in Multiple-Form Sets",
          "loss": "Injection of spoofed wheel speed signals causing inappropriate ABS activation",
          "asset": "Wheel Speed Sensors",
          "damage_scene": "An attacker with physical or CAN access injects falsified PWM wheel-speed signals. The ABS MCU misinterprets normal braking as wheel lock and activates pulse modulation, dramatically extending stopping distance and increasing accident risk.",
          "isChecked": false
        },
        {
          "id": "abs_deriv_4",
          "nodeId": "abs_can_transceiver",
          "task": "Threat Analysis",
          "name": "ATM Technique: CAN Bus Message Injection",
          "loss": "Injection of spoofed ABS status CAN frames affecting adjacent ECUs",
          "asset": "CAN Transceiver",
          "damage_scene": "An adversary connected to the in-vehicle CAN bus transmits fabricated ABS_Active and WheelSpeed CAN frames. The ECM and ESC/ESP receive false data, alter torque distribution and stability control, potentially inducing a spin or loss of vehicle stability.",
          "isChecked": false
        },
        {
          "id": "abs_deriv_5",
          "nodeId": "abs_obd_interface",
          "task": "Threat Analysis",
          "name": "CAPEC-167: Bluetooth Brute Force Attack / CWE-307: Improper Restriction of Excessive Authentication Attempts",
          "loss": "Brute-force of UDS SecurityAccess seed-key to gain privileged diagnostic session",
          "asset": "OBD-II Interface",
          "damage_scene": "An attacker connects a rogue diagnostic tool to the OBD-II port and performs automated seed-key brute-forcing using the short 16-bit seed space. After unlocking level 2 security, the attacker reprograms the ABS ECU or corrupts its NVM calibration, degrading braking performance.",
          "isChecked": false
        },
        {
          "id": "abs_deriv_6",
          "nodeId": "abs_data_flash",
          "task": "Threat Analysis",
          "name": "CWE-276: Incorrect Default Permissions on Calibration Data",
          "loss": "Tampering of ABS calibration parameters degrading stopping distance",
          "asset": "Data Flash",
          "damage_scene": "An attacker who obtains UDS programming access overwrites ABS threshold calibration values (slip ratio limits, pressure ramp rates) stored in Data Flash. The modified parameters cause the ABS system to intervene too early or too late, increasing stopping distance measurably beyond ISO 21434 safety targets.",
          "isChecked": false
        },
        {
          "id": "abs_deriv_7",
          "nodeId": "abs_debug_port",
          "task": "Threat Analysis",
          "name": "MITRE ICS Technique T0843: Program Download / Physical Access via JTAG",
          "loss": "Full ECU compromise through unlocked JTAG debug port in production hardware",
          "asset": "Debug Port",
          "damage_scene": "A production ABS ECU is found with the JTAG/SWD interface active and unprotected. An attacker extracts the full flash image (including Keys and firmware), patches the binary to disable ABS logic, and re-flashes the modified image, indistinguishable from legitimate firmware.",
          "isChecked": false
        },
        {
          "id": "abs_deriv_8",
          "nodeId": "abs_hydraulic_control_unit",
          "task": "Threat Analysis",
          "name": "ATM Technique: Manipulate Control Logic",
          "loss": "Denial of braking or asymmetric braking through actuator command injection",
          "asset": "Hydraulic Control Unit",
          "damage_scene": "An attacker who has compromised the ABS MCU firmware sends erroneous solenoid valve commands to the HCU. This causes asymmetric brake pressure modulation (e.g., locking one wheel while releasing another), resulting in severe vehicle yaw and potential rollover at highway speed.",
