  "damage_scenarios": {
    "_id": "ds-ivi-001",
    "model_id": "InfotainmentHeadUnit",
    "type": "damage",
    "Derivations": [
      {
        "id": "drv-001", "nodeId": "code-flash", "task": "Threat Analysis",
        "name": "Unsigned OTA Firmware Injection", "loss": "Integrity",
        "asset": "Code Flash", "damage_scene": "Attacker pushes unsigned firmware via OTA, overwriting Code Flash with malicious image",
        "isChecked": false
      },
      {
        "id": "drv-002", "nodeId": "bluetooth-module-ext", "task": "Threat Analysis",
        "name": "Bluetooth PII Exfiltration", "loss": "Confidentiality",
        "asset": "Bluetooth Module", "damage_scene": "Exploiting BLE pairing weakness to intercept or replay phonebook and call records",
        "isChecked": false
      },
      {
        "id": "drv-003", "nodeId": "gps-module", "task": "Threat Analysis",
        "name": "GPS Signal Spoofing", "loss": "Authenticity",
        "asset": "GPS Module", "damage_scene": "False GNSS signals fed to GPS Module causing incorrect navigation routing",
        "isChecked": false
      },
      {
        "id": "drv-004", "nodeId": "usb-port-ext", "task": "Threat Analysis",
        "name": "USB Malware Injection", "loss": "Integrity",
        "asset": "USB Port", "damage_scene": "Malicious USB device exploits driver stack to execute code on head unit OS",
        "isChecked": false
      },
      {
        "id": "drv-005", "nodeId": "debug-port", "task": "Threat Analysis",
        "name": "Debug Port JTAG Exploit", "loss": "Integrity",
        "asset": "Debug Port", "damage_scene": "Physical access to unlocked JTAG port allows full memory read/write of SoC",
        "isChecked": false
      },
      {
        "id": "drv-006", "nodeId": "can-transceiver", "task": "Threat Analysis",
        "name": "CAN Bus Frame Injection", "loss": "Integrity",
        "asset": "CAN Transceiver", "damage_scene": "Attacker injects spoofed CAN frames via IVI CAN gateway to control vehicle subsystems",
        "isChecked": false
      },
      {
        "id": "drv-007", "nodeId": "wifi-module-ext", "task": "Threat Analysis",
        "name": "Wi-Fi MITM Attack", "loss": "Confidentiality",
        "asset": "WiFi Module", "damage_scene": "Rogue AP intercepts cloud backend communications, exfiltrating OTA packages or credentials",
        "isChecked": false
      },
      {
        "id": "drv-008", "nodeId": "keys", "task": "Threat Analysis",
        "name": "Cryptographic Key Extraction", "loss": "Confidentiality",
        "asset": "Keys", "damage_scene": "Side-channel or memory disclosure attack extracts signing keys from SoC secure storage",
        "isChecked": false
      },
      {
        "id": "drv-009", "nodeId": "user-profiles", "task": "Threat Analysis",
        "name": "User PII Data Theft", "loss": "Confidentiality",
        "asset": "User Profiles", "damage_scene": "Unauthorized app or remote attacker reads stored driver profiles, preferences and location history",
        "isChecked": false
      },
      {
        "id": "drv-010", "nodeId": "navigation-data", "task": "Threat Analysis",
        "name": "Navigation Data Tampering", "loss": "Integrity",
        "asset": "Navigation Data", "damage_scene": "Attacker modifies cached map database or route data to mislead driver routing",
        "isChecked": false
      }
    ],
    "Details": [
      {
        "_id": "det-001",
        "Name": "OTA Firmware Tampering Attack",
        "Description": "Attacker intercepts or replaces the OTA update package delivered via Cloud Backend. Without signature verification on Code Flash write, a malicious firmware image is flashed to the SoC. This can introduce backdoors, disable safety interlocks or brick the head unit, disrupting all IVI functions.",
        "cyberLosses": [
          { "id": "cl-001-a", "name": "Integrity", "node": "Code Flash", "nodeId": "code-flash", "isSelected": true, "is_risk_added": false },
          { "id": "cl-001-b", "name": "Authenticity", "node": "OTA Package", "nodeId": "ota-package", "isSelected": true, "is_risk_added": false }
        ],
        "impacts": { "Safety Impact": "Moderate", "Financial Impact": "Major", "Operational Impact": "Major", "Privacy Impact": "Negligible" },
        "key": 1
      },
      {
        "_id": "det-002",
        "Name": "Bluetooth Hands-Free PII Leak",
        "Description": "Exploiting CVE-class BLE pairing vulnerabilities (BLESA, BIAS), an attacker within RF range intercepts the Bluetooth link between the Smartphone and Bluetooth Module. Phonebook entries, recent calls and SMS metadata are exfiltrated without driver awareness, violating GDPR and automotive PII regulations.",
        "cyberLosses": [
          { "id": "cl-002-a", "name": "Confidentiality", "node": "Bluetooth Module", "nodeId": "bluetooth-module-ext", "isSelected": true, "is_risk_added": false },
          { "id": "cl-002-b", "name": "Confidentiality", "node": "User Profiles", "nodeId": "user-profiles", "isSelected": true, "is_risk_added": false }
        ],
        "impacts": { "Safety Impact": "Negligible", "Financial Impact": "Moderate", "Operational Impact": "Minor", "Privacy Impact": "Major" },
        "key": 2
      },
      {
        "_id": "det-003",
        "Name": "GNSS Spoofing — False Navigation",
        "Description": "Using a software-defined radio, attacker broadcasts counterfeit GNSS signals stronger than genuine satellite signals. The GPS Module accepts false position data, causing the navigation system to route the driver to unintended locations. Combined with live traffic data manipulation this can cause significant safety incidents.",
        "cyberLosses": [
          { "id": "cl-003-a", "name": "Authenticity", "node": "GPS Module", "nodeId": "gps-module", "isSelected": true, "is_risk_added": false },
          { "id": "cl-003-b", "name": "Integrity", "node": "Navigation Data", "nodeId": "navigation-data", "isSelected": true, "is_risk_added": false }
        ],
        "impacts": { "Safety Impact": "Major", "Financial Impact": "Minor", "Operational Impact": "Moderate", "Privacy Impact": "Minor" },
        "key": 3
      },
      {
        "_id": "det-004",
        "Name": "Malicious USB Device Code Execution",
        "Description": "A USB device crafted to exploit HID or mass-storage driver vulnerabilities (BadUSB class) is inserted into the USB Port. The vulnerable USB driver stack on the SoC auto-mounts the device and executes payload code with elevated privileges, bypassing OS sandboxing. Attacker gains root shell on head unit OS.",
        "cyberLosses": [
          { "id": "cl-004-a", "name": "Integrity", "node": "USB Port", "nodeId": "usb-port-ext", "isSelected": true, "is_risk_added": false },
          { "id": "cl-004-b", "name": "Confidentiality", "node": "App Data", "nodeId": "app-data", "isSelected": true, "is_risk_added": false }
        ],
        "impacts": { "Safety Impact": "Minor", "Financial Impact": "Moderate", "Operational Impact": "Major", "Privacy Impact": "Moderate" },
        "key": 4
      },
      {
        "_id": "det-005",
        "Name": "Debug Port JTAG Physical Attack",
        "Description": "Attacker with brief physical access connects to the exposed JTAG/SWD Debug Port on the SoC. If production fuses are not blown, the debug interface allows full memory read/write: extraction of Keys, Certificates and firmware, or direct injection of malicious code into running processes.",
        "cyberLosses": [
          { "id": "cl-005-a", "name": "Integrity", "node": "Debug Port", "nodeId": "debug-port", "isSelected": true, "is_risk_added": false },
          { "id": "cl-005-b", "name": "Confidentiality", "node": "Keys", "nodeId": "keys", "isSelected": true, "is_risk_added": false }
        ],
        "impacts": { "Safety Impact": "Moderate", "Financial Impact": "Major", "Operational Impact": "Major", "Privacy Impact": "Major" },
        "key": 5
      },
      {
        "_id": "det-006",
        "Name": "CAN Injection via IVI Gateway",
        "Description": "The IVI CAN Transceiver bridges the infotainment domain to the vehicle CAN backbone. An attacker exploiting the head unit operating system (via USB or OTA) can inject crafted CAN frames through the CAN Transceiver to the Vehicle Network, potentially affecting powertrain, braking, or climate ECUs.",
        "cyberLosses": [
          { "id": "cl-006-a", "name": "Integrity", "node": "CAN Transceiver", "nodeId": "can-transceiver", "isSelected": true, "is_risk_added": false },
          { "id": "cl-006-b", "name": "Availability", "node": "Vehicle Network", "nodeId": "vehicle-network-ext", "isSelected": true, "is_risk_added": false }
        ],
        "impacts": { "Safety Impact": "Major", "Financial Impact": "Moderate", "Operational Impact": "Major", "Privacy Impact": "Negligible" },
        "key": 6
      },
      {
        "_id": "det-007",
        "Name": "Wi-Fi MITM — OTA Package Substitution",
        "Description": "Attacker sets up a rogue access point mimicking the vehicle's known SSID. The IVI WiFi Module connects to the rogue AP, allowing the attacker to intercept cloud backend traffic, strip TLS, and serve a modified OTA Package. If certificate pinning is absent, the malicious update is accepted.",
        "cyberLosses": [
          { "id": "cl-007-a", "name": "Confidentiality", "node": "WiFi Module", "nodeId": "wifi-module-ext", "isSelected": true, "is_risk_added": false },
          { "id": "cl-007-b", "name": "Integrity", "node": "OTA Package", "nodeId": "ota-package", "isSelected": true, "is_risk_added": false }
        ],
        "impacts": { "Safety Impact": "Moderate", "Financial Impact": "Major", "Operational Impact": "Major", "Privacy Impact": "Minor" },
        "key": 7
      },
      {
        "_id": "det-008",
        "Name": "Credential and Key Exfiltration",
        "Description": "A compromised application on the head unit OS leverages insecure inter-process communication or a kernel exploit to read cryptographic Keys and Credentials from Secure Storage. Extracted keys enable signing of arbitrary updates, decryption of sensitive communications, or impersonation of the vehicle ECU to cloud backends.",
        "cyberLosses": [
          { "id": "cl-008-a", "name": "Confidentiality", "node": "Keys", "nodeId": "keys", "isSelected": true, "is_risk_added": false },
          { "id": "cl-008-b", "name": "Confidentiality", "node": "Credentials", "nodeId": "credentials", "isSelected": true, "is_risk_added": false }
        ],
        "impacts": { "Safety Impact": "Minor", "Financial Impact": "Major", "Operational Impact": "Major", "Privacy Impact": "Major" },
        "key": 8
      },
      {
        "_id": "det-009",
        "Name": "User PII Mass Exfiltration",
        "Description": "Attacker exploiting a remote code execution vulnerability on the IVI network stack gains access to Storage and reads User Profiles containing driver identities, home/work addresses, biometric data and payment credentials linked via cloud accounts. This constitutes a major GDPR breach with regulatory and reputational consequences.",
        "cyberLosses": [
          { "id": "cl-009-a", "name": "Confidentiality", "node": "User Profiles", "nodeId": "user-profiles", "isSelected": true, "is_risk_added": false },
          { "id": "cl-009-b", "name": "Confidentiality", "node": "Credentials", "nodeId": "credentials", "isSelected": true, "is_risk_added": false }
        ],
        "impacts": { "Safety Impact": "Negligible", "Financial Impact": "Major", "Operational Impact": "Minor", "Privacy Impact": "Severe" },
        "key": 9
      },
      {
        "_id": "det-010",
        "Name": "Navigation Map Database Poisoning",
        "Description": "Attacker with remote access to Storage (via network exploit or OTA) overwrites the cached Navigation Data map database with crafted data containing false road closures, incorrect speed limits or non-existent routes. Drivers receive misleading routing guidance leading to safety hazards or excessive detours.",
        "cyberLosses": [
          { "id": "cl-010-a", "name": "Integrity", "node": "Navigation Data", "nodeId": "navigation-data", "isSelected": true, "is_risk_added": false },
          { "id": "cl-010-b", "name": "Authenticity", "node": "GPS Module", "nodeId": "gps-module", "isSelected": true, "is_risk_added": false }
        ],
        "impacts": { "Safety Impact": "Major", "Financial Impact": "Minor", "Operational Impact": "Moderate", "Privacy Impact": "Minor" },
        "key": 10
      }
    ]
  }
